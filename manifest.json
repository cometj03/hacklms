{
    "manifest_version": 3,
    "name": "Hack LMS",
    "description": "Utilies for SSU LMS",
    "version": "1.2.0",
    "icons": {
        "128": "canvas.png"
    },
    "permissions": [
        "scripting",
        "downloads"
    ],
    "host_permissions": [
        "*://canvas.ssu.ac.kr/"
    ],
    "action": {
        "default_popup": "popup/index.html"
    },
    "content_scripts": [
        {
            "matches": ["https://commons.ssu.ac.kr/em/*"],
            "js": ["video-iframe-listener.js"],
            "all_frames": true
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
}